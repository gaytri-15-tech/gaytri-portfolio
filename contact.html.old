<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Contact — Hande Gaytri</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <h1 class="site-title">Hande Gaytri</h1>
      <nav class="site-nav">
        <a href="index.html">Home</a>
        <a href="about.html">About</a>
        <a href="projects.html">Projects</a>
        <a href="skills.html">Skills</a>
        <a href="contact.html">Contact</a>
      </nav>
    </div>
  </header>

  <main class="container main-content">
    <h2>Contact</h2>
    <p>You can email me directly at <a href="mailto:handegaytri1@gmail.com">handegaytri1@gmail.com</a>, or use the form below to send a message through the website.</p>

    <form id="contactForm" action="https://formsubmit.co/handegaytri1@gmail.com" method="POST" target="_blank">
      <input type="hidden" name="_subject" value="New message from portfolio">
      <input type="hidden" name="_captcha" value="false">

      <label for="name">Name</label>
      <input id="name" name="name" required>

      <label for="email">Email</label>
      <input id="email" name="email" type="email" required>

      <label for="message">Message</label>
      <textarea id="message" name="message" rows="6" required></textarea>

      <button type="submit">Send Message</button>
    </form>

    <p class="note">Note: The form uses FormSubmit.co to deliver messages to my email without a backend.</p>
  </main>

  <script src="js/contact.js"></script>
  <footer class="site-footer">
    <div class="container">© 2026 Hande Gaytri</div>
  </footer>
</body>
</html>